                command:
                - cat
                tty: true
                resources:
                  requests:
                    memory: "512Mi"
                    cpu: "300m"
                  limits:
                    memory: "1Gi"
                    cpu: "500m"
                volumeMounts:
                - mountPath: /var/run/docker.sock
                  name: test-volume
              volumes:
              - name: test-volume
                hostPath:
                  path: /var/run/docker.sock
            """
        }
    }
    
    triggers {
        // Poll SCM regularly to pick up branch code updates automatically
        pollSCM('* * * * *')
    }
    
