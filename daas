## 4. Production DevSecOps Pipeline Blueprint
This complete Declarative pipeline script configures multi-container agent pods running Coverity static analysis scanners alongside native Docker tools. It is pre-configured to execute repository change checking polls automatically.

pipeline {
    agent {
        kubernetes {
            defaultContainer 'docker'
            yaml """
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: coverity-scan
                image: docker.repo.eng.netapp.com/global/devts-daas/coverity/coverity_scan:2021.12.1
                imagePullPolicy: Always
                command:
                - cat
                tty: true
                resources:
                  requests:
                    memory: "512Mi"
                    cpu: "300m"
                  limits:
                    memory: "5Gi"
                    cpu: "500m"
              - name: docker
                image: docker.repo.eng.netapp.com/global/devts-daas/daas_netapp/docker
                command:
                - cat
                tty: true
                resources:
                  requests:
                    memory: "512Mi"
                    cpu: "300m"
                  limits:
                    memory: "1Gi"
                    cpu: "500m"
                volumeMounts:
                - mountPath: /var/run/docker.sock
                  name: test-volume
              volumes:
              - name: test-volume
                hostPath:
                  path: /var/run/docker.sock
            """
        }
    }
    
    triggers {
        // Enforce systematic, short polling sweeps to detect Git repository changes
        pollSCM('* * * * *')
    }
    
    options {
        disableConcurrentBuilds()
    }
    
    environment {
        WORKSPACE           = "${env.WORKSPACE}"
        COVERITY_HOSTNAME   = "https://coverity.cls.eng.netapp.com"
        COVERITY_PORT       = 9090
        COVERITY_STREAM     = 'DaaS'
        ANALYSIS_TOOLS_BIN  = "/opt/coverity-analysis/bin"
        INTERMEDIATE_DIR    = "$WORKSPACE/CoverityIDIR"
        CONFIG_FILE         = "$WORKSPACE/coverityconfig/coverity_config.xml"
        AUTH_KEY            = "tools/coverity_auth-key.txt"
        CERT_FILE           = "tools/coverity_CA_cert.pem"
    }
    
    stages {
        stage('Static Application Security Testing') {
            steps {
                container('coverity-scan') {
                    echo "Executing Coverity SAST analysis stream: ${env.COVERITY_STREAM}"
                    // Insert local build compilation and coverity analysis command steps below
                }
            }
        }
    }
    
    post {
        always {
            echo "DevSecOps build sequence completed. Tearing down ephemeral pod resources."
        }
    }
}

⚠️ Infrastructure Advisory: If your pipeline execution layers encounter errors, or if you require modifications to the underlying Coverity base container engine image, contact the platform engineering group directly at ng-daas-dev.

